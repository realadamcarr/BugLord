rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    // ── Default deny all ────────────────────────────────────────────


    match /{document=**} {
      allow read, write: if false;
    }

    // ── Add collection rules below ──────────────────────────────────

    // ── Users ───────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if true;
      allow create: if isMe(uid)
        && request.resource.data.createdAt is timestamp;
      allow update: if isMe(uid)
        && (!('createdAt' in request.resource.data)
            || request.resource.data.createdAt == resource.data.createdAt);
    }

    // ── Friendships ─────────────────────────────────────────────────

    match /friendships/{friendshipId} {
      // resource is null when the document doesn't exist (e.g. existence
      // checks in sendFriendRequest).  Allow the get so the client
      // receives exists()==false instead of a permission error.
      allow read: if isSignedIn()
        && (resource == null || request.auth.uid in resource.data.uids);

      // Allow creation only when the authenticated user is one of the two UIDs.
      // The acceptFriendRequest transaction validates the pending request before
      // creating this document, so this is safe.
      allow create: if isSignedIn()
        && request.resource.data.uids.size() == 2
        && request.auth.uid in request.resource.data.uids;

      allow update, delete: if false;
    }

    // ── Friend Requests ─────────────────────────────────────────────

    match /friend_requests/{requestId} {
      // Both sender and recipient can read (get and list).
      // All queries MUST include a where clause on fromUid or toUid that
      // matches the authenticated user, so Firestore can verify every
      // returned document satisfies this rule.
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      // Only the sender can create, must start as 'pending'
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.status == 'pending'
        && request.resource.data.fromUid != request.resource.data.toUid;

      // toUid can accept or decline; fromUid can cancel
      allow update: if isSignedIn()
        && resource.data.status == 'pending'
        && (
          // toUid can accept or decline
          (request.auth.uid == resource.data.toUid
            && request.resource.data.status in ['accepted', 'declined'])
          ||
          // fromUid can cancel
          (request.auth.uid == resource.data.fromUid
            && request.resource.data.status == 'cancelled')
        );

      allow delete: if false;
    }

    // ── Inventories ─────────────────────────────────────────────────

    match /inventories/{uid}/bugs/{bugId} {
      // Owner can always read and write
      allow read, write: if isMe(uid);

      // Allow a trade participant to clear the trade lock on the other
      // party's bug.  Only lockedByTradeId and lockedAt may be changed,
      // and both must be set to null.
      allow update: if isSignedIn()
        && resource.data.lockedByTradeId != null
        && request.resource.data.lockedByTradeId == null
        && request.resource.data.lockedAt == null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['lockedByTradeId', 'lockedAt']);
    }

    // ── Trades ──────────────────────────────────────────────────────

    match /trades/{tradeId} {
      // Only participants can read
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      // Only fromUid can create, must start as 'proposed'
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.status == 'proposed';

      // Update rules for active trades (status must still be 'proposed')
      // Client can never set status to 'completed' — only the Cloud Function does that
      allow update: if isSignedIn()
        && resource.data.status == 'proposed'
        && request.resource.data.status != 'completed'
        && (
          // fromUid can cancel
          (request.auth.uid == resource.data.fromUid
            && request.resource.data.status == 'cancelled')
          ||
          // toUid can decline
          (request.auth.uid == resource.data.toUid
            && request.resource.data.status == 'declined')
          ||
          // toUid can set their offered bug (toBugId) when it's still empty
          (request.auth.uid == resource.data.toUid
            && resource.data.toBugId == ''
            && request.resource.data.toBugId != ''
            && request.resource.data.status == 'proposed')
          ||
          // Either participant can toggle their accept flag
          (request.auth.uid == resource.data.fromUid
            && request.resource.data.status == 'proposed')
          ||
          (request.auth.uid == resource.data.toUid
            && request.resource.data.status == 'proposed')
        );

      allow delete: if false;
    }
  }
}
